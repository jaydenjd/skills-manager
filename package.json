{
  "name": "skill-manager",
  "version": "0.2.6",
  "description": "Local multi-client skill manager for macOS",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "node --test",
    "dev": "vite",
    "electron": "wait-on tcp:5173 && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "build": "vite build",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "dist:mac:signed": "CSC_NAME=\"JUNDE WU (A8DZ968K75)\" APPLE_NOTARY_KEYCHAIN_PROFILE=\"${APPLE_NOTARY_KEYCHAIN_PROFILE:-skill-manager-notary}\" npm run dist:mac",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg --arm64 --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg --x64 --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.18",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.skillmanager.app",
    "productName": "Skill Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "build/icon.icns",
      "build/icon.ico",
      "node_modules/adm-zip/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "skills",
        "to": "skills"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "JUNDE WU (A8DZ968K75)",
      "target": [
        "dmg"
      ]
    },
    "afterSign": "build/notarize.cjs",
    "afterAllArtifactBuild": "build/notarize-dmg.cjs",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
